# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─────────────────────────────────────────────
# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# InsForge (backend/database)
# https://insforge.dev → tu proyecto → Settings → API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_INSFORGE_URL=https://<tu-proyecto>.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_API_KEY=

# ─────────────────────────────────────────────
# Anthropic (chat IA)
# https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Cron job — generar con: openssl rand -hex 32
# ─────────────────────────────────────────────
CRON_SECRET=
